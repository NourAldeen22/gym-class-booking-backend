@using Microsoft.AspNetCore.Identity
@model ApplicationUser
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Views/Shared/_CustomSecurityLayout.cshtml";

   
}


<div class="container-fluid justify-content mt-4">

    <!-- Header -->
    <h2 class="mb-4">User Profile</h2>


    <div class="container mt-4">
        <h2 class="mb-4 text-center text-md-start">User Profile</h2>

        @if (Model != null)
        {
            <div class="row">
                <div class="col-12 col-md-4 mb-4">
                    <div class="card shadow-sm p-4 text-center h-100">
                        <div class="profile-image-wrapper">
                            <img src="/images/user.png" class="rounded-circle mb-3" width="100" alt="User Image">
                        </div>

                        <h4>@Model.FullName</h4>
                        <p class="text-muted text-break">@Model.Email</p>

                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <p class="text-muted small"> @Model.PhoneNumber</p>
                        }

                        <div class="mb-3">
                            <span class="badge @(User.IsInRole("Admin") ? " bg-warning text-dark" : "bg-success" ) px-3
                                py-2">
                                @(User.IsInRole("Admin") ? "Admin" : "Member")
                            </span>
                        </div>

                        <div class="mt-auto pt-3">
                            <a class="btn btn-primary btn-sm me-2 w-100 mb-2" asp-area="Identity"
                               asp-page="/Account/Manage/Edit">
                                Edit Profile
                            </a>
                            <a class="btn btn-warning btn-sm w-100" asp-area="Identity"
                               asp-page="/Account/Manage/ChangePassword">
                                Change Password
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-8 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-secondary text-white d-flex align-items-center justify-content-between">
                            <span class="fw-bold">Booked Classes / Activities</span>
                            <span class="badge bg-light text-dark">
                                @(Model.AttendedClasses?.Count ?? 0) Bookings
                            </span>
                        </div>

                        <div class="card-body p-0">
                            @if (Model.AttendedClasses != null && Model.AttendedClasses.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Class Name</th>
                                                <th>Date</th>
                                                <th>Time</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var c in Model.AttendedClasses)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-primary">@c.Name</td>
                                                    <td>@c.EndTime.ToShortDateString()</td>
                                                    <td>@c.EndTime.ToShortTimeString()</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <p class="text-muted mb-0 fs-5">No bookings yet</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger text-center" role="alert">
                Unable to load user profile data. Please try logging in again.
            </div>
        }
    </div>