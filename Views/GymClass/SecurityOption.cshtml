<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="utf-8" />
    <title> @ViewData["Title"] Security-Option </title>
    @Layout = "_Layout"

</head>

<body>

    <div class="container">

        <partial name="_IdentitySaidbar" />


        <div class="main-content flex-grow-1 overflow-auto">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 shadow-sm">

                <span class="navbar-brand mb-0 h1"> @ViewData["PageName"]</span>
            </nav>

            <div class="content-body container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>




    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
