@model List<userMangment.ViewModels.UserProfileViewModel>
@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Home Page";
}


@if (TempData["Error"] != null)
{

    <div class="alert alert-danger col-6  alert-dismissible fade show" role="alert">
        <p> @TempData["Error"]</p>

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success col-6  alert-dismissible fade show" role="alert">
        <p> @TempData["Success"]</p>

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}



<table class="table">
    <thead>
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Email</th>

        </tr>
    </thead>
    <tbody>

        @if (Model != null)
        {
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>

                    <td>@user.Email</td>

                    <td>

                        @if (user.Email != User.Identity?.Name)
                        {
                            <form action="MakeMember" method="post">
                                <input type="hidden" name="userId" value="@user.UserId" />

                                @if (user.IsMember)
                                {
                                    <button type="submit" class="btn btn-sm btn-success">Set as a subscriber</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-danger">un subscriber</button>

                                
                                }

                            </form>
                        }

                        
                        else
                        {
                            <span class="badge bg-danger">You cannot edit your data (protected)</span>
                        }

                    </td>
                </tr>
            }
        }

       

       
           
             
            
       
    </tbody>

</table>